  "faqs": [
    {
      "category": "Acceso",
      "question": "¿Cómo recupero mi contraseña?",
      "answer": "En login, clic en '¿Has olvidado tu contraseña?', ingresa tu correo corporativo y recibirás un enlace de restablecimiento."
    },
    {
      "category": "Acceso",
      "question": "¿Puedo usar Google o Microsoft para iniciar sesión?",
      "answer": "Sí, en la pantalla de login encontrarás los iconos correspondientes. Al hacer clic, completa el formulario que se muestra."
    },
    {
      "category": "Asistencia",
      "question": "¿Qué significa cada estado de asistencia?",
      "answer": "Sin marca (no registró), Puntual (correcto), Tardanza (tarde), Falta (sin registro), Permiso (autorizado), Vacaciones, Feriado, Fuera de horario, Licencia, Personal de confianza."
    },
    {
      "category": "Asistencia",
      "question": "¿Cómo regularizo una marca?",
      "answer": "Asistencia > Regularizar Marcas > + Nueva Solicitud > + Agregar Nueva Marcación. Completa, verifica y envía. Debe ser aprobada."
    },
    {
      "category": "Solicitudes",
      "question": "¿Cuánto tarda en aprobarse una solicitud?",
      "answer": "Depende del aprobador asignado. Puedes verificar el estado en la pestaña correspondiente."
    },
    {
      "category": "Solicitudes",
      "question": "¿Puedo hacer una solicitud para varios colaboradores?",
      "answer": "Sí, si tienes rol con permiso 'Todos', tendrás habilitado el botón 'Solicitud Masiva'."
    },
    {
      "category": "Proyectos",
      "question": "¿Cómo pauso un proyecto?",
      "answer": "Clic en el botón ESTADO de la fila del proyecto. Justifica el cambio y guarda. El estado cambiará a AMARILLO."
    },
    {
      "category": "Proyectos",
      "question": "¿Qué pasa si pauso un proyecto?",
      "answer": "Los colaboradores no podrán cargar horas. Para reactivarlo, debes crear un nuevo requerimiento."
    },
    {
      "category": "Tareo",
      "question": "¿Qué pasa si no registro mis actividades a tiempo?",
      "answer": "Se contabilizará como tareo atrasado. A partir de 2 días sin registrar, se suma a los días laborados."
    },
    {
      "category": "Configuraciones",
      "question": "¿Puedo desactivar un área con colaboradores?",
      "answer": "No. El sistema bloqueará la acción indicando que tiene usuarios activos asignados."
    }
  ],
